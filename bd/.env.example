# ──────────────────────────────────────────────────────────────────────────────
# Task Manager API – environment variables
# Copy this file to .env and fill in the actual values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Supabase (or any PostgreSQL) connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# A long, random string used to sign JWT tokens.
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret

# JWT algorithm – HS256 is recommended for symmetric secrets
JWT_ALGORITHM=HS256

# Token lifetime in minutes (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Frontend URL for CORS (production deployment)
# Set this to your Vercel deployment URL
FRONTEND_URL=https://your-app.vercel.app
